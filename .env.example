# Smart Stadium Companion — example environment variables
# Copy this file to .env.local and fill in your own values.
# Get your key at: https://aistudio.google.com/app/apikey

GEMINI_API_KEY=your_gemini_api_key_here

# Session auth — used by lib/auth.ts
# Set SESSION_SECRET to a long random string (e.g. `openssl rand -hex 32`).
# A dev fallback is built-in but MUST be overridden in any real deployment.
SESSION_SECRET=replace-with-a-long-random-secret

# PIN required to log in as ops_staff (default: 1234 for demo)
OPS_STAFF_PIN=1234
