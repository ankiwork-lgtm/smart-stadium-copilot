{
  "name": "smart-stadium-copilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run && npm run test:smoke",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "node -e \"const {execSync}=require('child_process');if(!process.env.GEMINI_API_KEY){console.log('test:smoke skipped — GEMINI_API_KEY not set');process.exit(0)}execSync('npx tsx scripts/hello-gemini.ts',{stdio:'inherit'})\""
  },
  "dependencies": {
    "@google/genai": "^1.0.1",
    "next": "^16.2.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "eslint": "^9",
    "eslint-config-next": "15.3.4",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
